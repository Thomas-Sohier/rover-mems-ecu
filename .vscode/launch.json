{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch ECU mode debug",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "args": [
                "-mode",
                "debug",
                "-serialport",
                "/dev/ttyUSB0",
                "-ecutype",
                "1.9"
            ]
        }
    ]
}